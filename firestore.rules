rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Profils utilisateurs
    match /users/{userId} {
      // Lecture publique nécessaire pour que les acheteurs voient le nom et le badge du vendeur
      allow read: if true;
      // Un utilisateur ne peut créer, modifier ou supprimer que son propre profil
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }
    
    // Annonces : Lecture publique pour tous. 
    // Création par n'importe quel utilisateur connecté.
    // Modification et suppression réservées au vendeur de l'annonce.
    match /annonces/{annonceId} {
      allow read: if true; 
      allow create: if request.auth != null;
      allow update: if request.auth != null && (request.resource.data.vendeurId == request.auth.uid || resource.data.vendeurId == request.auth.uid);
      allow delete: if request.auth != null && resource.data.vendeurId == request.auth.uid;
    }

    // Avis : Lecture publique, création par les utilisateurs connectés
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow delete: if request.auth != null && resource.data.reviewerId == request.auth.uid;
    }

    // Signalements : Création uniquement par les utilisateurs connectés
    match /reports/{reportId} {
      allow create: if request.auth != null;
      allow read: if false; // Accès réservé à l'administration
    }

    // Logs et Audit
    match /auditLogs/{logId} {
      allow create: if request.auth != null;
      allow read: if false;
    }

    match /searchLogs/{logId} {
      allow create: if true;
      allow read: if false;
    }
  }
}