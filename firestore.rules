rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Profils utilisateurs : Lecture publique (pour voir les infos du vendeur), écriture restreinte au propriétaire
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Annonces : Lecture publique pour tous. Création et modification par les utilisateurs connectés.
    // Seul le vendeur peut supprimer son annonce.
    match /annonces/{annonceId} {
      allow read: if true; 
      allow create: if request.auth != null;
      allow update: if request.auth != null && (request.resource.data.vendeurId == request.auth.uid || resource.data.vendeurId == request.auth.uid);
      allow delete: if request.auth != null && resource.data.vendeurId == request.auth.uid;
    }

    // Avis : Lecture publique, création par les utilisateurs connectés (sauf sur leur propre profil, géré côté client)
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow delete: if request.auth != null && resource.data.reviewerId == request.auth.uid;
    }

    // Signalements : Création uniquement par les utilisateurs connectés
    match /reports/{reportId} {
      allow create: if request.auth != null;
      allow read: if false; // Accès réservé à l'administration via la console
    }

    // Journaux d'audit et logs de recherche
    match /auditLogs/{logId} {
      allow create: if request.auth != null;
      allow read: if false;
    }

    match /searchLogs/{logId} {
      allow create: if true;
      allow read: if false;
    }
  }
}