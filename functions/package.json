    "genkit": "1.29.0",
    "@genkit-ai/ai": "1.29.0",
    "@genkit-ai/google-genai": "1.29.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  },
  "private": true
}
